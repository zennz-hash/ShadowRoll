OAO"use client";

import { useState } from "react";
import { useAccount, useWriteContract, useReadContract, useWaitForTransactionReceipt } from "wagmi";
import { parseEther, stringToHex, erc20Abi } from "viem";
import ShadowRollABI from "../../ShadowRollABI.json";
import { ConnectButton } from "@rainbow-me/rainbowkit";
import { Loader2, ArrowRight, ShieldCheck, CheckCircle2 } from "lucide-react";
import Image from "next/image";

const CONTRACT_ADDRESS = ShadowRollABI.address as `0x${string}`;

// For demo purposes, we'll fetch the token address from the contract
// But since we need it for approval before write, we can use useReadContract
export default function EmployerPage() {
  const { isConnected } = useAccount();
  const [recipient, setRecipient] = useState("");
  const [amount, setAmount] = useState("");

  const { data: tokenAddress } = useReadContract({
    address: CONTRACT_ADDRESS,
    abi: ShadowRollABI.abi,
    functionName: "token",
  });

  const { data: poolBalance } = useReadContract({
    address: CONTRACT_ADDRESS,
    abi: ShadowRollABI.abi,
    functionName: "employerPool",
    args: [address as `0x${string}`],
    query: { refetchInterval: 5000 },
  });

  const { data: recipientList } = useReadContract({
    address: CONTRACT_ADDRESS,
    abi: ShadowRollABI.abi,
    functionName: "getRecipientList",
    query: {
      refetchInterval: 5000,
    }
  });

  const { writeContractAsync: approveToken, isPending: isApproving } = useWriteContract();
  const { writeContractAsync: schedulePayment, isPending: isScheduling, data: scheduleTxHash } = useWriteContract();

  const { isLoading: isWaitingForSchedule, isSuccess: isScheduleSuccess } = useWaitForTransactionReceipt({
    hash: scheduleTxHash,
  });

  const handleSchedule = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!recipient || !amount || !tokenAddress) return;

    try {
      const parsedAmount = parseEther(amount);
      
      // 1. Approve Token
      console.log("Approving token...");
      const approveTx = await approveToken({
        address: tokenAddress as `0x${string}`,
        abi: erc20Abi,
        functionName: "approve",
        args: [CONTRACT_ADDRESS, parsedAmount],
      });
      console.log("Approve Tx Hash:", approveTx);

      // 2. Fund Pool (Hiding exact transfer from the schedule)
      console.log("Funding pool...");
      const fundTx = await schedulePayment({
        address: CONTRACT_ADDRESS,
        abi: ShadowRollABI.abi,
        functionName: "fundPool",
        args: [parsedAmount],
      });
      console.log("Fund Pool Tx Hash:", fundTx);

      // 3. Schedule Payment
      console.log("Scheduling payment...");
      // In a real FHE environment, this is where we would use the Nox FHE client to encrypt the amount.
      // For this mock, we just send the amount as a hex string to satisfy the bytes calldata.
      const encryptedMock = stringToHex(amount); 
      
      const scheduleTx = await schedulePayment({
        address: CONTRACT_ADDRESS,
        abi: ShadowRollABI.abi,
        functionName: "schedulePayment",
        args: [recipient, encryptedMock],
      });
      console.log("Schedule Tx Hash:", scheduleTx);
    } catch (err) {
      console.error("Transaction failed:", err);
    }
  };

  return (
    <main className="min-h-screen bg-[var(--background)] p-8 font-sans flex flex-col items-center">
      <div className="w-full max-w-6xl flex justify-between items-center mb-12 border-b border-[var(--border)] pb-6">
        <div className="flex items-center gap-4">
          <Image src="/logo.png" alt="ShadowRoll Logo" width={40} height={40} className="object-contain" />
          <div>
            <h1 className="text-3xl font-bold tracking-tight text-[var(--foreground)]">Employer Dashboard</h1>
            <p className="text-[var(--muted-foreground)] mt-1">Schedule confidential salaries via iExec Nox</p>
          </div>
        </div>
        <ConnectButton />
      </div>

      {!isConnected ? (
        <div className="flex flex-col items-center justify-center py-20 text-center glass rounded-2xl p-12 w-full max-w-2xl border border-[var(--border)]">
          <ShieldCheck className="w-16 h-16 text-gray-300 mb-4" />
          <h2 className="text-2xl font-bold mb-2">Connect Your Wallet</h2>
          <p className="text-[var(--muted-foreground)] mb-6">Please connect your employer wallet to schedule private payments.</p>
          <ConnectButton />
        </div>
      ) : (
        <div className="flex flex-col gap-8 w-full max-w-6xl">
          {/* Pool Status Banner */}
          <div className="glass p-6 rounded-2xl border border-[var(--border)] flex items-center justify-between shadow-sm">
            <div>
              <h2 className="text-xl font-bold flex items-center gap-2">
                <ShieldCheck className="w-6 h-6 text-green-600" /> Shielded Pool Status
              </h2>
              <p className="text-[var(--muted-foreground)] text-sm">Total liquidity available for confidential salaries.</p>
            </div>
            <div className="text-right">
              <div className="text-3xl font-mono font-bold">
                {poolBalance ? (Number(poolBalance) / 1e18).toFixed(2) : "0.00"} <span className="text-sm text-gray-500">MTK</span>
              </div>
            </div>
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-8 w-full">
          {/* Scheduling Form */}
          <div className="glass p-6 rounded-2xl border border-[var(--border)] flex flex-col shadow-sm">
            <h2 className="text-xl font-semibold mb-6 flex items-center gap-2">
              <span className="w-8 h-8 rounded-full bg-black text-white flex items-center justify-center text-sm">1</span>
              New Confidential Payment
            </h2>
            <form onSubmit={handleSchedule} className="flex flex-col gap-5">
              <div>
                <label className="block text-sm font-medium text-[var(--foreground)] mb-1">Recipient Address</label>
                <input 
                  type="text" 
                  placeholder="0x..." 
                  value={recipient}
                  onChange={(e) => setRecipient(e.target.value)}
                  className="w-full p-3 bg-white border border-[var(--border)] rounded-xl focus:ring-2 focus:ring-black focus:outline-none font-mono text-sm transition-all"
                  required
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-[var(--foreground)] mb-1">Salary Amount (Tokens)</label>
                <div className="relative">
                  <input 
                    type="number" 
                    step="0.0001"
                    placeholder="1000.00" 
                    value={amount}
                    onChange={(e) => setAmount(e.target.value)}
                    className="w-full p-3 bg-white border border-[var(--border)] rounded-xl focus:ring-2 focus:ring-black focus:outline-none font-mono text-sm transition-all"
                    required
                  />
                  <div className="absolute right-3 top-3 text-gray-400 font-semibold text-sm">ERC20</div>
                </div>
              </div>
              
              <button 
                type="submit" 
                disabled={isApproving || isScheduling || isWaitingForSchedule || !recipient || !amount}
                className="mt-4 w-full bg-black text-white p-4 rounded-xl font-semibold hover:bg-gray-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
              >
                {(isApproving || isScheduling || isWaitingForSchedule) ? (
                  <><Loader2 className="w-5 h-5 animate-spin" /> Processing...</>
                ) : (
                  <><ShieldCheck className="w-5 h-5" /> Schedule Securely</>
                )}
              </button>
            </form>

            {isScheduleSuccess && (
              <div className="mt-4 p-4 bg-green-50 border border-green-200 rounded-xl flex flex-col gap-2">
                <div className="flex items-center gap-2 text-green-700 font-medium">
                  <CheckCircle2 className="w-5 h-5" /> Payment Scheduled!
                </div>
                <a 
                  href={`https://sepolia.arbiscan.io/tx/${scheduleTxHash}`} 
                  target="_blank" 
                  rel="noreferrer"
                  className="text-xs text-green-600 hover:underline flex items-center gap-1 break-all"
                >
                  View Ciphertext on Arbiscan <ArrowRight className="w-3 h-3" />
                </a>
              </div>
            )}
          </div>

          {/* Recipient List */}
          <div className="glass p-6 rounded-2xl border border-[var(--border)] shadow-sm">
             <h2 className="text-xl font-semibold mb-6 flex items-center gap-2">
              <span className="w-8 h-8 rounded-full bg-gray-200 text-gray-600 flex items-center justify-center text-sm">2</span>
              Active Recipients
            </h2>
            <div className="bg-white border border-[var(--border)] rounded-xl overflow-hidden h-[300px] overflow-y-auto">
              <table className="w-full text-left text-sm">
                <thead className="bg-[var(--muted)] text-[var(--muted-foreground)] sticky top-0">
                  <tr>
                    <th className="p-3 font-medium">Wallet Address</th>
                    <th className="p-3 font-medium text-right">Encrypted Salary</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-[var(--border)]">
                  {(recipientList as string[])?.length > 0 ? (
                    (recipientList as string[]).map((rec, idx) => (
                      <tr key={idx} className="hover:bg-gray-50 transition-colors">
                        <td className="p-3 font-mono text-xs">{rec}</td>
                        <td className="p-3 text-right">
                          <span className="inline-block bg-black text-white rounded px-2 py-1 text-xs font-mono font-bold tracking-wide">
                            [ ENCRYPTED BY NOX ]
                          </span>
                        </td>
                      </tr>
                    ))
                  ) : (
                    <tr>
                      <td colSpan={2} className="p-8 text-center text-gray-400">
                        No recipients scheduled yet.
                      </td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}
    </main>
  );
}
